    "@mui/lab": "6.0.1-beta.36",
    "@mui/material": "6.5.0",
    "@mui/x-date-pickers": "7.23.6",
    "@productivity-app/shared": "1.0.0",
    "bcryptjs": "3.0.3",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "express": "4.22.1",
    "express-rate-limit": "8.2.1",
    "express-validator": "7.3.1",
    "helmet": "8.1.0",
    "morgan": "1.10.1",
