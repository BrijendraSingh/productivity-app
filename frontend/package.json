{
  "name": "@productivity-app/frontend",
  "version": "1.0.0",
  "description": "React frontend for the Productivity App",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
