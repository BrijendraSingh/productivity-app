    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "5.1.4",
    "typescript": "5.9.3",
