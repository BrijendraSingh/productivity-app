[Unit]
Description=Productivity App Deploy Webhook
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
ExecStart=/usr/local/bin/webhook -hooks /etc/productivity-app/hooks.json -port 9000 -ip 127.0.0.1 -verbose
Restart=on-failure
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log /opt/productivity-app

[Install]
WantedBy=multi-user.target
